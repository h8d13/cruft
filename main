#!/usr/bin/env python3
import sys
from datetime import datetime
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent / "src"))

from duper import RED, RESET, collect_files, respect_gitignore, scan
from report import report

rep_n = f'report_{datetime.now().strftime("%H:%M:%S")}'

## input path       ## use '.' if none provided
root = Path(sys.argv[1]).resolve() if len(sys.argv) > 1 else Path.cwd()
## output dir       ## use default name if none provided
out_path = (
    Path(sys.argv[2]).expanduser() if len(sys.argv) > 2 else Path.cwd() / rep_n
)

if not root.is_dir():
    sys.exit(f"{RED}error:{RESET} '{root}' is not a directory")

files = collect_files(root, spec := respect_gitignore(root))
print(f"\nScanning {root} ({len(files)} files) ...")
results, warnings = scan(files)
report(results, root, len(files), out_path, warnings)
